# The Brownfield Cartographer — Environment Configuration

# --- LLM Providers (Set at least one for Semanticist/Navigator) ---

# Option 1: OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here

# Option 2: Google Gemini (Recommended - free tier available)
# GEMINI_API_KEY=AIza-your-gemini-key-here

# Option 3: OpenRouter (Access to many models)
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Option 4: Ollama (Local LLM)
# OLLAMA_BASE_URL=http://localhost:11434

# --- Model Tiering (Optional) ---
# The Semanticist uses two model tiers:
#   Fast  = cheap / high-throughput model for bulk purpose extraction & drift detection
#   Strong = higher-quality model for synthesis tasks (Day-One Q&A)
#
# Set both to the same value to disable tiering.
# LLM_MODEL_FAST=gemini-2.0-flash
# LLM_MODEL_STRONG=gemini-2.5-flash-preview-05-20

# Legacy: override BOTH tiers to a single model
# LLM_MODEL=gemini-2.0-flash

# --- Performance Controls (Optional) ---
# SEMANTICIST_MAX_MODULES=60
# SEMANTICIST_MAX_SECONDS=900

# --- Logging (Optional) ---
# LOG_LEVEL=INFO
