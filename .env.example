# The Brownfield Cartographer — Environment Configuration

# --- LLM Providers (Set at least one for Semanticist/Navigator) ---

# Option 1: OpenAI
# OPENAI_API_KEY=sk-your-openai-key-here

# Option 2: Google Gemini (Recommended - free tier available)
# GEMINI_API_KEY=AIza-your-gemini-key-here

# Option 3: OpenRouter (Access to many models)
# OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Option 4: Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434

# --- Model Selection (Optional) ---
LLM_MODEL=qwen3.5:397b-cloud
# LLM_MODEL=gemini-2.0-flash
# LLM_MODEL=google/gemini-2.0-flash-exp:free
# LLM_MODEL=llama3

# --- Logging (Optional) ---
# LOG_LEVEL=INFO
